{
  "name": "@bunito/core",
  "version": "0.0.5",
  "description": "Core runtime for bunito with app lifecycle, modules, dependency injection, config, logger, and server primitives.",
  "keywords": [
    "bunito",
    "bun",
    "typescript",
    "framework",
    "dependency-injection",
    "modules",
    "config",
    "logger",
    "server"
  ],
  "author": "Stanisław Głogowski <hello@bunito.dev>",
  "license": "MIT",
  "homepage": "https://bunito.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/bunito-dev/bunito.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/bunito-dev/bunito/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config/index.ts",
    "./container": "./src/container/index.ts",
    "./logger": "./src/logger/index.ts",
    "./server": "./src/server/index.ts"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@bunito/common": "workspace:0.0.5"
  },
  "devDependencies": {
    "@types/bun": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.11"
  }
}