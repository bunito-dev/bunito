{
  "name": "@bunito/cli",
  "version": "0.0.10",
  "description": "Command-line tools for running bunito projects.",
  "keywords": [
    "bunito",
    "cli",
    "bun",
    "typescript",
    "framework"
  ],
  "author": "Stanisław Głogowski <hello@bunito.dev>",
  "license": "MIT",
  "homepage": "https://bunito.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/bunito-dev/bunito.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/bunito-dev/bunito/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "bunito": "./src/main.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "imports": {
    "#commands": "./src/commands/index.ts",
    "#common": "./src/common/index.ts",
    "#context": "./src/context/index.ts",
    "#services": "./src/services/index.ts",
    "#templates": "./src/templates/index.ts"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "cli": "bun run ./src/main.ts"
  },
  "dependencies": {
    "@bunito/common": "workspace:0.0.10",
    "@inquirer/prompts": "8.4.2",
    "yargs": "18.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/yargs": "17.0.35"
  },
  "engines": {
    "bun": ">=1.3.10"
  }
}
