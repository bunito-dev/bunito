{
  "name": "@bunito/bunito",
  "version": "0.0.14",
  "description": "Main application entrypoint for the Bun-first bunito framework.",
  "keywords": [
    "bunito",
    "bun",
    "framework",
    "dependency-injection",
    "typescript"
  ],
  "author": "Stanisław Głogowski <hello@bunito.dev>",
  "license": "MIT",
  "homepage": "https://bunito.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/bunito-dev/bunito.git",
    "directory": "packages/bunito"
  },
  "bugs": {
    "url": "https://github.com/bunito-dev/bunito/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./biome.json": "./biome.base.json",
    "./tsconfig.json": "./tsconfig.base.json"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE",
    "biome.base.json",
    "tsconfig.base.json"
  ],
  "dependencies": {
    "@bunito/app": "workspace:0.0.14",
    "@bunito/common": "workspace:0.0.14",
    "@bunito/config": "workspace:0.0.14",
    "@bunito/container": "workspace:0.0.14",
    "@bunito/logger": "workspace:0.0.14"
  },
  "devDependencies": {},
  "engines": {
    "bun": ">=1.3.10"
  }
}
