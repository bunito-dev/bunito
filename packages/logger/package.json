{
  "name": "@bunito/logger",
  "version": "0.0.6",
  "description": "Logger module and JSON/pretty logging extensions for bunito.",
  "keywords": [
    "bunito",
    "logger",
    "logging",
    "json",
    "pretty"
  ],
  "author": "Stanisław Głogowski <hello@bunito.dev>",
  "license": "MIT",
  "homepage": "https://bunito.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/bunito-dev/bunito.git",
    "directory": "packages/logger"
  },
  "bugs": {
    "url": "https://github.com/bunito-dev/bunito/issues"
  },
  "publishConfig": {
    "access": "public"
  },
